# Base URL of the Market Consensus FastAPI backend.
# Local dev: leave unset — Vite proxies /api -> http://localhost:8000 (see vite.config.ts).
# Production (Vercel): set to your deployed API origin, e.g. https://market-consensus.up.railway.app
VITE_API_BASE=

# Force the bundled sample data instead of hitting the API (useful for design work / demos).
# Any non-empty value turns it on. When unset, the app tries the API and falls back to sample
# data only if the API is unreachable or has no data yet.
VITE_USE_SAMPLE=
